---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Lauren Hay — Home">
  <section class="grid" style="grid-template-columns: 160px 1fr; align-items:start;">
    <img src="public/IMG_1783.JPG" alt="Headshot of Lauren Hay" style="width:160px; height:160px; object-fit:cover; border-radius:16px; border:1px solid #e6e6e6;" />
    <div class="card">
      <h1 style="margin-top:0;">Hi — I’m Lauren Hay.</h1>
      <p>
        I’m a particle physicist / data scientist. I work on collider physics, jet substructure,
        and large-scale analysis workflows.
      </p>
      <p style="margin-bottom:0;">
        <a href="/projects">Projects</a> · <a href="/cv">CV</a> · <a href="/blog">Blog</a>
      </p>
    </div>
  </section>

  <section class="grid" style="margin-top:22px;">
    <div class="card">
      <h2 style="margin-top:0;">Current focus</h2>
      <ul>
        <li>Jet physics & substructure measurements</li>
        <li>Unfolding / response-matrix methods</li>
        <li>HPC + modern Python tooling for analysis</li>
      </ul>
    </div>

    <div class="card">
      <h2 style="margin-top:0;">Contact</h2>
      <ul>
        <li>Email: <a href="mailto:you@renhay.com">you@renhay.com</a></li>
        <li>GitHub: <a href="https://github.com/laurenhay">github.com/laurenhay</a></li>
        <li>LinkedIn / Scholar: (add links)</li>
      </ul>
    </div>
  </section>
</BaseLayout>