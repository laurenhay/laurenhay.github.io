---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Lauren Hay's personal website" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">Lauren Hay</a>
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Lauren Hay. All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --accent: #4f46e5;
    --accent-light: #818cf8;
    --accent-dark: #3730a3;
    --text: #1e293b;
    --text-light: #64748b;
    --bg: #ffffff;
    --bg-alt: #f8fafc;
    --border: #e2e8f0;
    --max-width: 900px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
      Ubuntu, Cantarell, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
  }

  header {
    position: sticky;
    top: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  nav .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    text-decoration: none;
    color: var(--text-light);
    font-weight: 500;
    transition: color 0.2s;
  }

  nav ul a:hover {
    color: var(--accent);
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  footer {
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 2rem;
    margin-top: 4rem;
    color: var(--text-light);
    font-size: 0.875rem;
  }

  h1, h2, h3 {
    line-height: 1.2;
  }

  a {
    color: var(--accent);
  }

  section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .section-divider {
    width: 3rem;
    height: 3px;
    background: var(--accent);
    margin-bottom: 2rem;
    border-radius: 2px;
  }
</style>
